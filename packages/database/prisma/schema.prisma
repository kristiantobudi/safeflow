// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  firstName    String
  lastName     String?
  email        String  @unique
  username     String  @unique
  password     String
  role         Role    @default(USER)
  jobTitle     JobTitle @default(REQUESTER)
  isActive     Boolean @default(false)
  isVerified   Boolean @default(false)
  isEmailVerified  Boolean    @default(false)
  refreshToken String?

  // ─── 2FA / OTP ─────────────────────────────────────────
  twoFactorEnabled     Boolean  @default(false)
  twoFactorSecret      String? // encrypted TOTP secret
  twoFactorBackupCodes String[] @default([]) // hashed backup codes

    // ─── SSO / OAuth ──────────────────────────────────────
  authProvider     AuthProvider @default(LOCAL)
  googleId         String?   @unique  // Google sub ID
  googleEmail      String?
  avatarUrl        String?
  displayName      String?

  // ─── Invitation ───────────────────────────────────────
  invitationToken      String?      // token invite yang dipakai saat register
  invitedByEmail       String?      // email admin yang mengundang

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs       AuditLog[]
  notifications    Notification[]
  sentInvitations      Invitation[] @relation("InvitedBy")
  positions       Position[]
  exams           Exam[]        @relation("ExamCreator")
  examsModified   Exam[]        @relation("ExamModifier")
  examDeleted     Exam[]        @relation("ExamDeleter")
  certificates    Certificate[]
  modules         Module[]      @relation("ModuleCreator")
  modifiedModules Module[]      @relation("ModuleModifier")
  deletedModules  Module[]      @relation("ModuleDeleter")
  examAttempts    ExamAttempt[]
  projects        Project[]     @relation("ProjectCreator")
  projectsModified Project[]     @relation("ProjectModifier")
  projectsDeleted Project[]     @relation("ProjectDeleter")
  projectsApproved Project[]     @relation("ProjectApprovedBy")
  projectsRejected Project[]     @relation("ProjectRejectedBy")
  approvalLogs    ApprovalLog[] @relation("ApprovalLogs")

  @@map("users")
}

model Invitation {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  email        String
  token        String           @unique
  role         Role             @default(USER)
  status       InvitationStatus @default(PENDING)

  invitedById  String           @db.ObjectId
  invitedBy    User             @relation("InvitedBy", fields: [invitedById], references: [id])

  acceptedById String?          @db.ObjectId
  acceptedAt   DateTime?
  revokedAt    DateTime?
  expiresAt    DateTime
  note         String?

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([email])
  @@index([status])
  @@map("invitations")
}

model Notification {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  type        NotificationType
  title       String
  message     String
  data        Json?
  isRead      Boolean          @default(false)
  readAt      DateTime?
  visibleTo   Role[]           @default([ADMIN])
  recipientId String?          @db.ObjectId
  recipient   User?            @relation(fields: [recipientId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?     @db.ObjectId
  user      User?       @relation(fields: [userId], references: [id])
  action    String // e.g. "USER_LOGIN", "2FA_ENABLED", "PROFILE_UPDATE"
  entity    String? // e.g. "User", "Post"
  entityId  String? // ID of affected entity
  oldValue  Json? // state before change
  newValue  Json? // state after change
  ipAddress String?
  userAgent String?
  requestId String?
  status    AuditStatus @default(SUCCESS)
  metadata  Json? // extra info
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Position {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  userId   String? @db.ObjectId
  user     User?   @relation(fields: [userId], references: [id])
  jobTitle String
  level    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("positions")
}

model Exam {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  moduleId    String?       @db.ObjectId
  module      Module?       @relation(fields: [moduleId], references: [id])
  duration    Int
  maxAttempts Int?
  question    Question[]
  attempts    ExamAttempt[]
  isDeleted   Boolean       @default(false)
  createdBy   String?       @db.ObjectId
  creator     User?         @relation("ExamCreator", fields: [createdBy], references: [id])
  modifyBy    String?       @db.ObjectId
  modifier    User?         @relation("ExamModifier", fields: [modifyBy], references: [id])
  deletedBy   String?       @db.ObjectId
  deleter     User?         @relation("ExamDeleter", fields: [deletedBy], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  certificates    Certificate[]

  @@index([createdBy])
  @@index([modifyBy])
  @@index([deletedBy])
  @@map("exams")
}

model Question {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  examId        String?   @db.ObjectId
  exam          Exam?     @relation(fields: [examId], references: [id])
  question      String
  options       String[]
  correctAnswer String
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  module        Module?   @relation(fields: [moduleId], references: [id])
  moduleId      String?   @db.ObjectId

  @@index([examId])
  @@map("questions")
}

model ExamAttempt {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  examId String? @db.ObjectId
  exam   Exam?   @relation(fields: [examId], references: [id])
  userId String  @db.ObjectId
  user   User    @relation(fields: [userId], references: [id])

  questionIds String[]

  startTime DateTime
  endTime   DateTime
  status    AttemptStatus @default(ONGOING)
  score     Int?
  isPassed  Boolean?
  passedAt  DateTime?
  totalQuestions    Int?
  answeredQuestions Int?
  correctQuestions  Int?

  answers   Answer[]
  certificates    Certificate[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  @@index([examId])
  @@index([userId])
  @@map("exam_attempts")
}

model Answer {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  attemptId  String @db.ObjectId
  questionId String @db.ObjectId

  attempt ExamAttempt @relation(fields: [attemptId], references: [id])

  selectedAnswer String
  isCorrect      Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("answers")
}

model Certificate {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String?   @db.ObjectId
  user       User?     @relation(fields: [userId], references: [id])
  moduleId   String?   @db.ObjectId
  module     Module?   @relation(fields: [moduleId], references: [id])
  examId     String?   @db.ObjectId
  exam       Exam?     @relation(fields: [examId], references: [id])
  attemptId  String?   @db.ObjectId
  attempt    ExamAttempt? @relation(fields: [attemptId], references: [id])

  certNumber String    @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  expiresAt  DateTime?

  @@index([userId])
  @@index([moduleId])
  @@map("certificates")
}

model Module {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  createdBy   String?   @db.ObjectId
  creator     User?     @relation("ModuleCreator", fields: [createdBy], references: [id])
  modifyBy    String?   @db.ObjectId
  modifier    User?     @relation("ModuleModifier", fields: [modifyBy], references: [id])
  deletedBy   String?   @db.ObjectId
  deleter     User?     @relation("ModuleDeleter", fields: [deletedBy], references: [id])
  title       String    @unique
  description String?
  files       ModuleFile[]
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  certificate Certificate[]
  exam        Exam[]
  question    Question[]

  @@index([createdBy])
  @@index([modifyBy])
  @@index([deletedBy])
  @@map("modules")
}

model ModuleFile {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  moduleId  String   @db.ObjectId
  module    Module   @relation(fields: [moduleId], references: [id])

  filename  String
  url       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleId])
  @@map("module_files")
}

model Project {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  unitKerja      String
  lokasiKerja String?
  tanggal String?
  revisiDocument Int?
  statusDocument String?
  status ProjectStatus @default(DRAFT)
  hiracs    hirac[]

  createdAt DateTime @default(now())
  createdBy String? @db.ObjectId
  creator User? @relation("ProjectCreator", fields: [createdBy], references: [id])
  modifyBy String? @db.ObjectId
  modifier User? @relation("ProjectModifier", fields: [modifyBy], references: [id])
  deletedBy String? @db.ObjectId
  deleter User? @relation("ProjectDeleter", fields: [deletedBy], references: [id])
  
  isDeleted Boolean @default(false)
  isApproved Boolean @default(false)
  isRejected Boolean @default(false)
  
  approvedBy String? @db.ObjectId
  approvedUser User? @relation("ProjectApprovedBy", fields: [approvedBy], references: [id])
  rejectedBy String? @db.ObjectId
  rejectedUser User? @relation("ProjectRejectedBy", fields: [rejectedBy], references: [id])
  
  approvedAt DateTime?
  rejectedAt DateTime?
  deletedAt DateTime?
  updatedAt DateTime @updatedAt


  approvalLogs ApprovalLog[]

  @@map("projects")
}

model ApprovalLog {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String        @db.ObjectId
  project     Project       @relation(fields: [projectId], references: [id])
  
  approvedBy  String        @db.ObjectId
  approver    User          @relation("ApprovalLogs", fields: [approvedBy], references: [id])
  
  level       Int           // 1, 2, 3 dst
  action      ApprovalAction
  comment     String?
  createdAt   DateTime      @default(now())

  @@map("approval_logs")
}

model hirac {
  id                               String             @id @default(auto()) @map("_id") @db.ObjectId
  no                               Int?
  kegiatan                         String
  kategori                         ActivityCategory   // R, NR, E
  identifikasiBahaya               String
  akibatRisiko                     String
  
  // Penilaian Risiko Awal
  penilaianAwal                    RiskAssessment
  risikoDapatDiterimaAwal          Boolean            @default(false)
  
  peraturanTerkait                 String?
  
  // Hirarki Pengendalian Risiko
  pengendalian                     String
  
  // Penilaian Risiko Lanjutan (Residual Risk)
  penilaianLanjutan                RiskAssessment
  risikoDapatDiterimaLanjutan      Boolean            @default(false)
  
  peluang                          String?
  picId                            String?            @db.ObjectId
  status                           StatusControl      @default(OPEN)
  
  // Metadata untuk Alur Digital (berdasarkan file SafeFlow/HSE Digital)
  createdAt                        DateTime           @default(now())
  updatedAt                        DateTime           @updatedAt
  projectId                        String?            @db.ObjectId
  project                          Project?           @relation(fields: [projectId], references: [id])
}

// Objek Tertanam untuk Penilaian Risiko
type RiskAssessment {
  akibat             Int       // Nilai numerik dari sheet Keterangan
  kemungkinan        String    // A, B, C, D, E
  tingkatRisiko      RiskLevel // Low, Medium, High, Extreme
}

// Objek Tertanam untuk 5 Hirarki Pengendalian

// Enums untuk standarisasi data
enum ActivityCategory {
  R   // Routine
  NR  // Non-Routine
  E   // Emergency
}

enum RiskLevel {
  L   // Low
  M   // Medium
  H   // High
  E   // Extreme
}

enum StatusControl {
  OPEN
  IN_PROGRESS
  CLOSED
  REVISED
}

enum Role {
  USER
  ADMIN
  EXAMINER
  VERIFICATOR
}

enum JobTitle {
  REQUESTER
  VERIFICATOR
}

enum AuditStatus {
  SUCCESS
  FAILURE
  PENDING
}

enum AttemptStatus {
  ONGOING
  FINISHED
  EXPIRED
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum NotificationType {
  USER_REGISTERED_LOCAL
  USER_REGISTERED_GOOGLE
  USER_INVITED
  USER_INVITATION_ACCEPTED
  USER_DEACTIVATED
  SYSTEM
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ApprovalAction {
  SUBMITTED
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum ProjectStatus {
  DRAFT         // Baru dibuat, belum diajukan
  SUBMITTED     // Diajukan oleh creator
  L1_REVIEW     // Menunggu approval level 1 (misal: VERIFICATOR)
  L2_REVIEW     // Menunggu approval level 2 (misal: EXAMINER)  
  APPROVED      // Final approved (ADMIN)
  REJECTED      // Ditolak di level manapun
  REVISION      // Dikembalikan untuk revisi
}
