// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  firstName    String
  lastName     String?
  email        String  @unique
  username     String  @unique
  password     String
  role         Role    @default(USER)
  jobTitle     JobTitle @default(REQUESTER)
  isActive     Boolean @default(false)
  isVerified   Boolean @default(false)
  isEmailVerified  Boolean    @default(false)
  refreshToken String?

  // ─── 2FA / OTP ─────────────────────────────────────────
  twoFactorEnabled     Boolean  @default(false)
  twoFactorSecret      String? // encrypted TOTP secret
  twoFactorBackupCodes String[] @default([]) // hashed backup codes

    // ─── SSO / OAuth ──────────────────────────────────────
  authProvider     AuthProvider @default(LOCAL)
  googleId         String?   @unique  // Google sub ID
  googleEmail      String?
  avatarUrl        String?
  displayName      String?

  // ─── Invitation ───────────────────────────────────────
  invitationToken      String?      // token invite yang dipakai saat register
  invitedByEmail       String?      // email admin yang mengundang

  // ─── Vendor ───────────────────────────────────────
  vendorId String?
  vendor   Vendor?  @relation(fields: [vendorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs       AuditLog[]
  notifications    Notification[]
  sentInvitations      Invitation[] @relation("InvitedBy")
  positions       Position[]
  exams           Exam[]        @relation("ExamCreator")
  examsModified   Exam[]        @relation("ExamModifier")
  examDeleted     Exam[]        @relation("ExamDeleter")
  certificates    Certificate[]
  modules         Module[]      @relation("ModuleCreator")
  modifiedModules Module[]      @relation("ModuleModifier")
  deletedModules  Module[]      @relation("ModuleDeleter")
  examAttempts    ExamAttempt[]
  projects        Project[]     @relation("ProjectCreator")
  projectsModified Project[]     @relation("ProjectModifier")
  projectsDeleted Project[]     @relation("ProjectDeleter")
  projectsApproved Project[]     @relation("ProjectApprovedBy")
  projectsRejected Project[]     @relation("ProjectRejectedBy")
  versions         ProjectVersion[] @relation("VersionReviewer")
  versionsSubmitted ProjectVersion[] @relation("VersionSubmitter")
  versionApproval VersionApproval[] @relation("ApprovalReviewer")

  jsaProjectsCreated JsaProject[] @relation("JsaProjectCreatedBy")
  jsaProjectsModified JsaProject[] @relation("JsaProjectUpdatedBy")
  jsaProjectsDeleted JsaProject[] @relation("JsaProjectDeletedBy")
  jsaProjectsApproved JsaProject[] @relation("JsaProjectApprovedBy")
  jsaProjectsRejected JsaProject[] @relation("JsaProjectRejectedBy")

  jsaVersionsSubmitted JsaProjectVersion[] @relation("JsaProjectVersionSubmitter")
  jsaVersionsReviewed JsaProjectVersion[] @relation("JsaProjectVersionReviewer")

  jsaVersionsApproved JsaVersionApproval[] @relation("JsaProjectVersionApprovalReviewer")

  @@map("users")
}

model Invitation {
  id           String           @id @default(cuid())
  email        String
  token        String           @unique
  role         Role             @default(USER)
  status       InvitationStatus @default(PENDING)

  invitedById  String
  invitedBy    User             @relation("InvitedBy", fields: [invitedById], references: [id])

  acceptedById String?
  acceptedAt   DateTime?
  revokedAt    DateTime?
  expiresAt    DateTime
  note         String?

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([email])
  @@index([status])
  @@map("invitations")
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  data        Json?
  isRead      Boolean          @default(false)
  readAt      DateTime?
  visibleTo   Role[]           @default([ADMIN])
  recipientId String?
  recipient   User?            @relation(fields: [recipientId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  action    String // e.g. "USER_LOGIN", "2FA_ENABLED", "PROFILE_UPDATE"
  entity    String? // e.g. "User", "Post"
  entityId  String? // ID of affected entity
  oldValue  Json? // state before change
  newValue  Json? // state after change
  ipAddress String?
  userAgent String?
  requestId String?
  status    AuditStatus @default(SUCCESS)
  metadata  Json? // extra info
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Position {
  id       String  @id @default(cuid())
  userId   String?
  user     User?   @relation(fields: [userId], references: [id])
  jobTitle String
  level    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("positions")
}

model Exam {
  id          String        @id @default(cuid())
  moduleId    String?
  module      Module?       @relation(fields: [moduleId], references: [id])
  duration    Int
  maxAttempts Int?
  question    Question[]
  attempts    ExamAttempt[]
  isDeleted   Boolean       @default(false)
  createdBy   String?
  creator     User?         @relation("ExamCreator", fields: [createdBy], references: [id])
  modifyBy    String?
  modifier    User?         @relation("ExamModifier", fields: [modifyBy], references: [id])
  deletedBy   String?
  deleter     User?         @relation("ExamDeleter", fields: [deletedBy], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  certificates    Certificate[]

  @@index([createdBy])
  @@index([modifyBy])
  @@index([deletedBy])
  @@map("exams")
}

model Question {
  id            String    @id @default(cuid())
  examId        String?
  exam          Exam?     @relation(fields: [examId], references: [id])
  question      String
  options       String[]
  correctAnswer String
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  module        Module?   @relation(fields: [moduleId], references: [id])
  moduleId      String?

  @@index([examId])
  @@map("questions")
}

model ExamAttempt {
  id     String  @id @default(cuid())
  examId String?
  exam   Exam?   @relation(fields: [examId], references: [id])
  userId String
  user   User    @relation(fields: [userId], references: [id])

  questionIds String[] @default([])

  startTime DateTime
  endTime   DateTime
  status    AttemptStatus @default(ONGOING)
  score     Int?
  isPassed  Boolean?
  passedAt  DateTime?
  totalQuestions    Int?
  answeredQuestions Int?
  correctQuestions  Int?

  answers   Answer[]
  certificates    Certificate[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  @@index([examId])
  @@index([userId])
  @@map("exam_attempts")
}

model Answer {
  id         String @id @default(cuid())
  attemptId  String
  questionId String

  attempt ExamAttempt @relation(fields: [attemptId], references: [id])

  selectedAnswer String
  isCorrect      Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("answers")
}

model Certificate {
  id         String    @id @default(cuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  moduleId   String?
  module     Module?   @relation(fields: [moduleId], references: [id])
  examId     String?
  exam       Exam?     @relation(fields: [examId], references: [id])
  attemptId  String?
  attempt    ExamAttempt? @relation(fields: [attemptId], references: [id])

  certNumber String    @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  expiresAt  DateTime?

  @@index([userId])
  @@index([moduleId])
  @@map("certificates")
}

model Module {
  id          String    @id @default(cuid())
  createdBy   String?
  creator     User?     @relation("ModuleCreator", fields: [createdBy], references: [id])
  modifyBy    String?
  modifier    User?     @relation("ModuleModifier", fields: [modifyBy], references: [id])
  deletedBy   String?
  deleter     User?     @relation("ModuleDeleter", fields: [deletedBy], references: [id])
  title       String    @unique
  description String?
  files       ModuleFile[]
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  certificate Certificate[]
  exam        Exam[]
  question    Question[]

  @@index([createdBy])
  @@index([modifyBy])
  @@index([deletedBy])
  @@map("modules")
}

model ModuleFile {
  id        String   @id @default(cuid())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id])

  filename  String
  url       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleId])
  @@map("module_files")
}

model Project {
  id        String   @id @default(cuid())
  unitKerja      String
  lokasiKerja String?
  tanggal String?
  revisiDocument Int?
  statusDocument String?
  status ProjectStatus @default(DRAFT)
  hiracs    Hirac[]

  createdAt DateTime @default(now())
  createdBy String?
  creator User? @relation("ProjectCreator", fields: [createdBy], references: [id])
  modifyBy String?
  modifier User? @relation("ProjectModifier", fields: [modifyBy], references: [id])
  deletedBy String?
  deleter User? @relation("ProjectDeleter", fields: [deletedBy], references: [id])
  
  isDeleted Boolean @default(false)
  
  approvedBy String?
  approvedUser User? @relation("ProjectApprovedBy", fields: [approvedBy], references: [id])
  rejectedBy String?
  rejectedUser User? @relation("ProjectRejectedBy", fields: [rejectedBy], references: [id])
  
  approvedAt DateTime?
  rejectedAt DateTime?
  deletedAt DateTime?
  updatedAt DateTime @updatedAt

  approvalStatus ProjectStatus @default(DRAFT)

  versions          ProjectVersion[]   // ← tambah ini
  currentVersionId  String?            // pointer ke versi aktif

  @@index([createdBy])
  @@index([modifyBy])
  @@index([deletedBy])
  @@map("projects")
  @@index([status])
  @@index([approvalStatus])
  @@index([unitKerja])
}

// version untuk project
model ProjectVersion {
  id            String        @id @default(cuid())
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id])

  versionNumber Int           // 1, 2, 3, dst
  label         String?       // misal: "Revisi 1 - Perubahan APD"
  changeNote    String?       // ringkasan perubahan dari versi sebelumnya

  status        VersionStatus @default(DRAFT)
  submittedBy   String?
  submitter     User?         @relation("VersionSubmitter", fields: [submittedBy], references: [id])
  submittedAt   DateTime?

  // Siapa yang approve/reject versi ini
  reviewedBy    String?
  reviewer      User?         @relation("VersionReviewer", fields: [reviewedBy], references: [id])
  reviewedAt    DateTime?
  reviewNote    String?

  hiracs        HiracVersion[]
  approvalSteps VersionApproval[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([projectId, versionNumber])
  @@index([projectId])
  @@index([status])
  @@map("project_versions")
}

// version untuk approval project
model VersionApproval {
  id               String          @id @default(cuid())
  projectVersionId String
  projectVersion   ProjectVersion  @relation(fields: [projectVersionId], references: [id])

  stepOrder        Int
  requiredRole     Role
  status           ApprovalStatus  @default(PENDING)

  approvedBy       String?
  approver         User?           @relation("ApprovalReviewer", fields: [approvedBy], references: [id])
  approvedAt       DateTime?
  note             String?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([projectVersionId])
  @@map("version_approvals")
}

model Hirac {
  id                               String             @id @default(cuid())
  no                               Int?
  kegiatan                         String
  kategori                         ActivityCategory   // R, NR, E
  identifikasiBahaya               String
  akibatRisiko                     String
  
  // Penilaian Risiko Awal (Flattened RiskAssessment)
  penilaianAwalAkibat              Int
  penilaianAwalKemungkinan         String
  penilaianAwalTingkatRisiko       RiskLevel
  risikoDapatDiterimaAwal          Boolean            @default(false)
  
  peraturanTerkait                 String?
  
  // Hirarki Pengendalian Risiko
  pengendalian                     String
  
  // Penilaian Risiko Lanjutan (Flattened RiskAssessment)
  penilaianLanjutanAkibat          Int
  penilaianLanjutanKemungkinan     String
  penilaianLanjutanTingkatRisiko   RiskLevel
  risikoDapatDiterimaLanjutan      Boolean            @default(false)
  
  peluang                          String?
  picId                            String?
  status                           StatusControl      @default(OPEN)

  versions    HiracVersion[]
  jsaProjects JsaProject[]

  // ─── Vendor ───────────────────────────────────────
  vendors    Vendor[]

  // Tandai apakah baris ini masih aktif atau sudah superseded
  isActive    Boolean   @default(true)
  
  // Metadata untuk Alur Digital (berdasarkan file SafeFlow/HSE Digital)
  createdAt                        DateTime           @default(now())
  updatedAt                        DateTime           @updatedAt
  projectId                        String?
  project                          Project?           @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([isActive])
  @@map("hiracs")
  @@index([status])
  @@index([kategori])
  @@index([penilaianAwalTingkatRisiko]) 
}

// version untuk hirac
model HiracVersion {
  id               String          @id @default(cuid())
  projectVersionId String
  projectVersion   ProjectVersion  @relation(fields: [projectVersionId], references: [id])

  // Referensi ke Hirac "master" (untuk tracking baris yang sama lintas versi)
  hiracId          String?
  hirac            Hirac?          @relation(fields: [hiracId], references: [id])

  // ── Semua field Hirac di-snapshot di sini ──────────────────
  no                               Int?
  kegiatan                         String
  kategori                         ActivityCategory
  identifikasiBahaya               String
  akibatRisiko                     String
  penilaianAwalAkibat              Int
  penilaianAwalKemungkinan         String
  penilaianAwalTingkatRisiko       RiskLevel
  risikoDapatDiterimaAwal          Boolean
  peraturanTerkait                 String?
  pengendalian                     String
  penilaianLanjutanAkibat          Int
  penilaianLanjutanKemungkinan     String
  penilaianLanjutanTingkatRisiko   RiskLevel
  risikoDapatDiterimaLanjutan      Boolean
  peluang                          String?
  picId                            String?
  status                           StatusControl

  // ── Metadata diff ──────────────────────────────────────────
  diffType         DiffType        @default(UNCHANGED)
  // ADDED, REMOVED, MODIFIED, UNCHANGED
  // → untuk highlight di UI compare

  jsaVersions      JsaProjectVersion[]

  // ── Metadata versioning ──────────────────────────────────
  versionNumber    Int
  isLatest         Boolean         @default(true)

  createdAt        DateTime        @default(now())

  @@index([projectVersionId])
  @@index([hiracId])
  @@map("hirac_versions")
}

model JsaProject {
  id  String @id @default(cuid())
  noJsa           String?   // Nomor JSA
  jenisKegiatan   String    // Job Activity — e.g. "PENGUKURAN (SURVEY)"
  lokasiKegiatan  String?   // Job Location
  tanggalDibuat   DateTime  @default(now())
  revisiKe        Int       @default(0)  // Revision number (00, 01, …)
  referensiHirarc String?

  pelaksanaUtama  String?   // Supervisor in Charge
  hseInCharge     String?   // HSE In Charge

  hiracs Hirac[]

  createdBy String
  creator User? @relation("JsaProjectCreatedBy", fields: [createdBy], references: [id])
  updatedBy String?
  modifyBy User? @relation("JsaProjectUpdatedBy", fields: [updatedBy], references: [id])
  deletedBy String?
  deleter User? @relation("JsaProjectDeletedBy", fields: [deletedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  isDeleted Boolean @default(false)
  
  approvedBy String?
  approvedAt DateTime?
  approvedUser User? @relation("JsaProjectApprovedBy", fields: [approvedBy], references: [id])

  rejectedBy String?
  rejectedAt DateTime?
  rejectedUser User? @relation("JsaProjectRejectedBy", fields: [rejectedBy], references: [id])

  approvalStatus ApprovalStatus @default(PENDING)

  versions JsaProjectVersion[]
  currentVersionId String?
  apd JsaApd?

  jsas Jsa[]

  @@index([currentVersionId])
  @@map("jsa_project")
  @@index([approvalStatus])
  @@index([isDeleted])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([deletedBy])
  @@index([approvedBy])
  @@index([rejectedBy])
}

model JsaApd {
  id           String     @id @default(cuid())
  jsaProjectId String     @unique
  jsaProject   JsaProject @relation(fields: [jsaProjectId], references: [id])

  safetyHelmet      Boolean @default(false)
  safetyShoes       Boolean @default(false)
  gloves            Boolean @default(false)
  safetyGlasses     Boolean @default(false)
  safetyVest        Boolean @default(false)
  safetyBodyHarness Boolean @default(false)
  others            String? // free-text untuk APD lain

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("jsa_apd")
}

model JsaProjectVersion {
  id  String @id @default(cuid())

  // Referensi ke HiracVersion
  hiracVersionId String
  hiracVersion   HiracVersion  @relation(fields: [hiracVersionId], references: [id])
  
  // Referensi Ke JSA Master
  jsaId          String?
  jsaProject     JsaProject?   @relation(fields: [jsaId], references: [id])

  // ── Metadata versioning ──────────────────────────────────
  versionNumber    Int
  label            String?
  changeNote       String?

  status        VersionStatus @default(DRAFT)
  submittedBy   String?
  submitter     User?         @relation("JsaProjectVersionSubmitter", fields: [submittedBy], references: [id])
  submittedAt   DateTime?

  // Siapa yang approve/reject versi ini
  reviewedBy    String?
  reviewer      User?         @relation("JsaProjectVersionReviewer", fields: [reviewedBy], references: [id])
  reviewedAt    DateTime?
  reviewNote    String?

  jsaVersions JsaVersion[]

  // Approval Steps
  approvalSteps JsaVersionApproval[]

  jsas JsaEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hiracVersionId])
  @@index([jsaId])
  @@map("jsa_project_versions")
}

model JsaVersionApproval {
  id  String @id @default(cuid())

  jsaProjectVersionId String
  jsaProjectVersion   JsaProjectVersion @relation(fields: [jsaProjectVersionId], references: [id])

  stepOrder        Int
  requiredRole     Role
  status           ApprovalStatus  @default(PENDING)

  approvedBy       String?
  approver         User?           @relation("JsaProjectVersionApprovalReviewer", fields: [approvedBy], references: [id])
  approvedAt       DateTime?
  note             String?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("jsa_version_approvals")
}

model JsaEntry {
  id String @id @default(cuid())

  jsaProjectVersionId String
  jsaProjectVersion   JsaProjectVersion @relation(fields: [jsaProjectVersionId], references: [id])

  // Nomor urut & pengelompokan (A1, A2, B1, B2, …)
  no              Int?    // angka urut dalam satu kategori
  kategoriGrup    String? // huruf kategori: "A", "B", "C", dst
  namaGrup        String? // label kategori: "Persiapan", "Pelaksanaan", dst

  // Isi langkah kerja
  langkahKerja    String  // Job Description
  penanggungJawab String? // PIC — e.g. "SME/SMO/SMHSE"

  // Diff untuk versioning compare
  diffType DiffType @default(UNCHANGED)

  bahaya          JsaBahaya[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jsaProjectVersionId])
  @@map("jsa_entries")
}

model JsaBahaya {
  id         String   @id @default(cuid())
  jsaEntryId String
  jsaEntry   JsaEntry @relation(fields: [jsaEntryId], references: [id])

  // Tipe sumber bahaya sesuai form (Man / Machine / Method / Material / Env)
  tipePotensi  TipePotensi
  deskripsi    String      // isi bahaya, e.g. "Cidera otot akibat mengangkat secara manual"
  urutan       Int         @default(0)

  penanggulangan JsaPenanggulangan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jsaEntryId])
  @@map("jsa_bahaya")
}

model JsaPenanggulangan {
  id          String    @id @default(cuid())
  jsaBahayaId String
  jsaBahaya   JsaBahaya @relation(fields: [jsaBahayaId], references: [id])

  // Hierarki kontrol sesuai form (Adm / PPE / RE / El / Sub)
  tipeKontrol  TipeKontrol
  deskripsi    String       // isi penanggulangan, e.g. "Melakukan Tool box meeting sebelum pekerjaan"
  urutan       Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jsaBahayaId])
  @@map("jsa_penanggulangan")
}

model Jsa {
  id  String @id @default(cuid())
  no Int
  katergoriLangkah String
  langkahKerja String
  penanggungJawab String

  jsaProjectId String
  jsaProject   JsaProject @relation(fields: [jsaProjectId], references: [id])

  @@map("jsas")
}

model JsaVersion {
  id  String @id @default(cuid())

  jsaProjectVersionId String
  jsaProjectVersion   JsaProjectVersion @relation(fields: [jsaProjectVersionId], references: [id])

  @@map("jsa_versions")
}

model Session {
  sid       String   @id
  sess      Json
  expire    DateTime

  @@map("session")
}

model Vendor {
  id  String @id @default(cuid())

  vendorName String
  vendorAddress String
  vendorPhone String
  vendorEmail String
  vendorWebsite String?
  vendorLogo String?
  vendorDescription String?
  vendorStatus VendorStatus @default(ACTIVE)
  vendorCreatedAt DateTime @default(now())
  vendorUpdatedAt DateTime @updatedAt

  // ─── Worker Vendor ───────────────────────────────────────
  workerVendor WorkerVendor[]

  // ─── Hirac ───────────────────────────────────────
  hiracs Hirac[]

  // ─── User ───────────────────────────────────────
  user User[]

  @@map("vendors")
}

model WorkerVendor {
  id String @id @default(cuid())

  workerName String
  workerAddress String
  workerPhone String
  workerStatus String
  workerCreatedAt DateTime @default(now())
  workerUpdatedAt DateTime @updatedAt

  vendorId String
  vendor   Vendor   @relation(fields: [vendorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("worker_vendors")
  @@index([vendorId])
}

// Objek Tertanam untuk Penilaian Risiko

// Objek Tertanam untuk 5 Hirarki Pengendalian

// Enums untuk standarisasi data
enum ActivityCategory {
  R   // Routine
  NR  // Non-Routine
  E   // Emergency
}

enum RiskLevel {
  L   // Low
  M   // Medium
  H   // High
  E   // Extreme
}

enum StatusControl {
  OPEN
  IN_PROGRESS
  CLOSED
  REVISED
}

enum Role {
  USER
  ADMIN
  EXAMINER
  VERIFICATOR
}

enum JobTitle {
  REQUESTER
  VERIFICATOR
}

enum AuditStatus {
  SUCCESS
  FAILURE
  PENDING
}

enum AttemptStatus {
  ONGOING
  FINISHED
  EXPIRED
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum NotificationType {
  USER_REGISTERED_LOCAL
  USER_REGISTERED_GOOGLE
  USER_INVITED
  USER_INVITATION_ACCEPTED
  USER_DEACTIVATED
  SYSTEM
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
